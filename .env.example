# Environment: 'inside' or 'production'
ENVIRONMENT=inside

# HTTP Basic Auth for inside.smugmug.net
INSIDE_AUTH_USER=
INSIDE_AUTH_PASS=

# SmugMug login credentials
SMUGMUG_QA_USERNAME=
SMUGMUG_QA_PASSWORD=

# SmugMug API (OAuth 1.0a)
SMUGMUG_API_KEY=
SMUGMUG_API_SECRET=
SMUGMUG_OAUTH_TOKEN=
SMUGMUG_OAUTH_TOKEN_SECRET=

# Test album key (pre-seeded album for image upload tests)
TEST_ALBUM_KEY=

# Test account nickname
TEST_NICKNAME=qa-pro
