# Environment: 'inside' or 'production' (REQUIRED — must be set explicitly)
ENVIRONMENT=

# HTTP Basic Auth for inside.smugmug.net
INSIDE_AUTH_USER=
INSIDE_AUTH_PASS=

# SmugMug login credentials (username: automated+render-testing@smugmug.com)
SMUGMUG_QA_PASSWORD=

# SmugMug API (OAuth 1.0a)
SMUGMUG_API_KEY=
SMUGMUG_API_SECRET=
SMUGMUG_OAUTH_TOKEN=
SMUGMUG_OAUTH_TOKEN_SECRET=

# Local test images directory (absolute path, no trailing slash)
TEST_IMAGES_DIR=
