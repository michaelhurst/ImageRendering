{
  "name": "smugmug-image-display-tests",
  "version": "1.0.0",
  "description": "Playwright tests for SmugMug image display quality, color accuracy, sizing, orientation, and metadata",
  "main": "index.js",
  "scripts": {
    "test:inside": "ENVIRONMENT=inside pnpm exec playwright test",
    "test:production": "ENVIRONMENT=production pnpm exec playwright test",
    "test:inside:local": "ENVIRONMENT=inside pnpm exec playwright test --project=api-tests --project=ui-tests",
    "test:production:local": "ENVIRONMENT=production pnpm exec playwright test --project=api-tests --project=ui-tests",
    "test:inside:smugmug": "ENVIRONMENT=inside pnpm exec playwright test --project=smugmug-api-tests --project=smugmug-ui-tests",
    "test:production:smugmug": "ENVIRONMENT=production pnpm exec playwright test --project=smugmug-api-tests --project=smugmug-ui-tests",
    "test:update": "pnpm exec playwright test --update-snapshots",
    "test:report": "pnpm exec playwright show-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "sharp": "^0.33.0",
    "exifr": "^7.1.3",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0",
    "dotenv": "^16.4.0",
    "serve": "^14.2.6"
  }
}
