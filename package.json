{
  "name": "smugmug-image-display-tests",
  "version": "1.0.0",
  "description": "Playwright tests for SmugMug image display quality, color accuracy, sizing, orientation, and metadata",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:render": "npx playwright test tests/image-render.spec.ts",
    "test:quality": "npx playwright test tests/image-quality.spec.ts",
    "test:color": "npx playwright test tests/color-accuracy.spec.ts",
    "test:sizing": "npx playwright test tests/image-sizing.spec.ts",
    "test:orientation": "npx playwright test tests/exif-orientation.spec.ts",
    "test:metadata-preservation": "npx playwright test tests/metadata-preservation.spec.ts",
    "test:metadata-display": "npx playwright test tests/metadata-display.spec.ts",
    "test:metadata-api": "npx playwright test tests/metadata-api.spec.ts",
    "test:poi": "npx playwright test tests/point-of-interest.spec.ts",
    "test:watermark": "npx playwright test tests/watermark.spec.ts",
    "test:resolution-cap": "npx playwright test tests/resolution-cap.spec.ts",
    "test:api-quality": "npx playwright test tests/api-image-quality.spec.ts",
    "test:api-sizing": "npx playwright test tests/api-image-sizing.spec.ts",
    "test:api-orientation": "npx playwright test tests/api-exif-orientation.spec.ts",
    "test:api-metadata": "npx playwright test tests/api-metadata-preservation.spec.ts",
    "test:api-metadata-display": "npx playwright test tests/api-metadata-display.spec.ts",
    "test:api-metadata-api": "npx playwright test tests/api-metadata-api.spec.ts",
    "test:api-poi": "npx playwright test tests/api-point-of-interest.spec.ts",
    "test:api-watermark": "npx playwright test tests/api-watermark.spec.ts",
    "test:api-resolution-cap": "npx playwright test tests/api-resolution-cap.spec.ts",
    "test:api-text-overlay": "npx playwright test tests/api-text-overlay.spec.ts",
    "test:smugmug": "npx playwright test --project=smugmug-api-tests --project=smugmug-ui-tests",
    "test:local": "npx playwright test --project=api-tests --project=ui-tests",
    "test:update": "npx playwright test --update-snapshots",
    "test:report": "npx playwright show-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "sharp": "^0.33.0",
    "exifr": "^7.1.3",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0",
    "dotenv": "^16.4.0",
    "serve": "^14.2.6"
  }
}
